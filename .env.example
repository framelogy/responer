# Database SQL connection.
# MySQL example:
# DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/responer"
# PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/responer?schema=public"
DATABASE_URL="mysql://root:password@localhost:3306/responer"

# NextAuth secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Login
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
